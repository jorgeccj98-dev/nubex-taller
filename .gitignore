## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# Build results
[Dd]ebug/
[Rr]elease/
x64/
x86/
build/
bld/
[Bb]in/
[Oo]bj/

# Visual Studio cache
.vs/

# Rider
.idea/

# VS Code
.vscode/

# .NET Core
project.lock.json
project.fragment.lock.json
artifacts/

# ASP.NET Scaffolding
ScaffoldingReadMe.txt

# Logs
*.log

# SQL Server files
*.mdf
*.ldf

# NuGet
*.nupkg
# The packages folder can be ignored because of Package Restore
**/packages/*
!**/packages/build/

# NuGet v3
*.nuget.props
*.nuget.targets

# Microsoft Azure Build Output
csx/
*.build.csdef

# Publish output
*.pubxml
*.publishproj

# IIS Express
.vs/
*.iisExpress/

# OS files
.DS_Store
Thumbs.db

# Environment variables
.env
.env.*

# node_modules (si usas frontend)
node_modules/

# dist / wwwroot generados
wwwroot/dist/
wwwroot/lib/

# Coverage
coverage/
*.coverage
*.coveragexml