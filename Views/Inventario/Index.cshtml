@model IEnumerable<DanimecApp.Models.InventarioItem>
@{
    ViewData["Title"] = "Gestión de Inventario";
    var categorias = ViewBag.Categorias as IEnumerable<string> ?? Enumerable.Empty<string>();
}

<div class="page-header">
    <div class="d-flex align-center gap-16">
        <div>
            <h1 class="page-title">Inventario de Repuestos</h1>
            <p class="page-subtitle">Gestión centralizada de existencias y niveles críticos para mantenimiento preventivo y correctivo.</p>
        </div>
        <div class="ms-auto d-flex gap-8">
            @if ((int)(ViewBag.Alertas ?? 0) > 0)
            {
                <span class="chip chip-alert" style="font-size:13px;padding:6px 14px">
                    <span class="material-icons-round" style="font-size:16px">warning</span>
                    @ViewBag.Alertas item(s) con stock crítico
                </span>
            }
            <button class="btn-primary-dn" onclick="toggleModal('modalNuevoItem')">
                <span class="material-icons-round" style="font-size:18px">add</span>
                Nuevo Item
            </button>
        </div>
    </div>
</div>

<div class="page-body">

    <!-- Search & Filter -->
    <div class="d-flex align-center gap-16 mb-16" style="flex-wrap:wrap">
        <form method="get" class="d-flex align-center gap-12" style="flex:1">
            <div class="search-bar" style="max-width:380px">
                <span class="material-icons-round">search</span>
                <input type="text" name="buscar" placeholder="Buscar por nombre o código..." value="@ViewBag.Buscar" />
            </div>
            <select name="categoria" class="form-control-dn" style="width:180px">
                <option value="">Todas las categorías</option>
                @foreach (var cat in categorias)
                {
                    <option value="@cat" selected="@(ViewBag.CategoriaFiltro == cat)">@cat</option>
                }
            </select>
            <button type="submit" class="btn-primary-dn" style="padding:8px 16px">Filtrar</button>
            <a asp-action="Index" class="btn-ghost-dn" style="padding:7px 14px;font-size:12px">Limpiar</a>
        </form>
    </div>

    <!-- Inventory Cards Grid -->
    <div class="inv-grid">
        @foreach (var item in Model)
        {
            var pct = item.StockMinimo > 0 ? Math.Min(100, (item.StockActual * 100 / (item.StockMinimo * 2))) : 100;
            <div class="inv-card @(item.TieneAlerta ? "alert" : "")">
                <div class="inv-card-code">@(item.Codigo ?? "—")</div>
                <div class="inv-card-name">@item.Nombre</div>
                <div class="inv-card-cat">@(item.Categoria ?? "General") · @(item.Proveedor ?? "—")</div>

                @if (item.TieneAlerta)
                {
                    <div style="margin-top:10px">
                        <span class="chip chip-vencido">⚠ Stock Crítico</span>
                    </div>
                }

                <div class="inv-stock" style="margin-top:12px">
                    <span class="stock-num">@item.StockActual</span>
                    <div class="stock-bar-wrap">
                        <div class="stock-bar @(item.TieneAlerta ? "low" : "")" style="width:@(pct)%"></div>
                    </div>
                    <span class="text-muted-dn">min @item.StockMinimo</span>
                </div>

                <div style="margin-top:12px;display:flex;justify-content:space-between;align-items:center">
                    <div>
                        <div class="text-muted-dn">Precio Venta</div>
                        <div class="fw-semibold" style="color:var(--primary-container)">Bs @item.PrecioVenta.ToString("N2")</div>
                    </div>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn-ghost-dn" style="font-size:12px;padding:6px 12px">Editar</a>
                </div>
            </div>
        }

        @if (!Model.Any())
        {
            <div style="grid-column:1/-1;text-align:center;padding:48px;color:var(--on-surface-variant)">
                <span class="material-icons-round" style="font-size:48px;display:block;margin-bottom:12px;opacity:.25">inventory_2</span>
                No hay items en inventario.
            </div>
        }
    </div>

    <!-- Analysis Card -->
    <div class="diagnostic-card">
        <div class="diag-header">
            <span class="material-icons-round">insights</span>
            <span class="diag-header-title">Análisis de Reposición</span>
        </div>
        <div class="diag-body">
            Se ha detectado un incremento del 15% en la demanda de Filtros de Aire durante las últimas dos semanas.
            Considere aumentar el stock de seguridad en el próximo pedido a proveedores para evitar quiebres.
            <div style="margin-top:12px">
                <a asp-action="Index" asp-route-categoria="Filtros" class="btn-ghost-dn" style="font-size:12px;padding:6px 14px">
                    Ver Filtros
                </a>
            </div>
        </div>
    </div>

</div>

<!-- Modal Nuevo Item -->
<div id="modalNuevoItem" style="display:none;position:fixed;inset:0;background:rgba(25,27,34,.5);z-index:200;align-items:center;justify-content:center">
    <div style="background:#fff;border-radius:16px;padding:28px;width:560px;max-width:95vw;box-shadow:0 24px 48px rgba(0,0,0,.2);max-height:90vh;overflow-y:auto">
        <div class="form-section-title">Nuevo Item de Inventario</div>
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <div class="form-grid-2">
                <div class="form-group">
                    <label class="form-label">Código</label>
                    <input name="Codigo" class="form-control-dn" placeholder="Ej. FLT-001" />
                </div>
                <div class="form-group">
                    <label class="form-label">Categoría</label>
                    <input name="Categoria" class="form-control-dn" placeholder="Ej. Filtros, Frenos..." list="catList" />
                    <datalist id="catList">
                        @foreach (var cat in categorias) { <option value="@cat" /> }
                    </datalist>
                </div>
                <div class="form-group form-grid-full">
                    <label class="form-label">Nombre *</label>
                    <input name="Nombre" required class="form-control-dn" placeholder="Nombre del repuesto o material" />
                </div>
                <div class="form-group">
                    <label class="form-label">Stock Actual</label>
                    <input name="StockActual" type="number" class="form-control-dn" value="0" min="0" />
                </div>
                <div class="form-group">
                    <label class="form-label">Stock Mínimo</label>
                    <input name="StockMinimo" type="number" class="form-control-dn" value="5" min="0" />
                </div>
                <div class="form-group">
                    <label class="form-label">Precio Compra</label>
                    <input name="PrecioCompra" type="number" step="0.01" class="form-control-dn" value="0" />
                </div>
                <div class="form-group">
                    <label class="form-label">Precio Venta</label>
                    <input name="PrecioVenta" type="number" step="0.01" class="form-control-dn" value="0" />
                </div>
                <div class="form-group form-grid-full">
                    <label class="form-label">Proveedor</label>
                    <input name="Proveedor" class="form-control-dn" placeholder="Nombre del proveedor" />
                </div>
            </div>
            <div class="d-flex gap-8" style="margin-top:20px">
                <button type="submit" class="btn-primary-dn">Guardar Item</button>
                <button type="button" class="btn-ghost-dn" onclick="toggleModal('modalNuevoItem')">Cancelar</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
function toggleModal(id) {
    const m = document.getElementById(id);
    m.style.display = m.style.display === 'flex' ? 'none' : 'flex';
}
</script>
}
