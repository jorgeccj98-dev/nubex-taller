<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — DANIMEC</title>
    <link rel="stylesheet" href="~/css/danimec.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
<div class="app-wrapper">

    <!-- ══ SIDEBAR ══ -->
    <!-- Overlay móvil -->
    <div class="sidebar-overlay" id="sidebarOverlay"></div>

    <nav class="sidebar" id="sidebar">
        <div class="sidebar-brand">
            <div class="brand-logo-area" style="display: flex; align-items: center; width: 100%; padding-right: 12px;">
                <img src="~/img/logo.png" alt="Logo" style="max-height: 45px; max-width: 100%; object-fit: contain; transition: all 0.3s ease;" />
            </div>
            <button class="sidebar-toggle" id="sidebarToggle" title="Colapsar menú" aria-label="Toggle sidebar">
                <span class="material-icons-round">menu_open</span>
            </button>
        </div>

        <div class="sidebar-nav">
            <span class="nav-label">Principal</span>
            <a class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "active" : "")"
               asp-controller="Dashboard" asp-action="Index">
                <span class="material-icons-round">dashboard</span>
                <span class="nav-text">Dashboard</span>
            </a>
            <a class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "NotasServicio" && ViewContext.RouteData.Values["action"]?.ToString() == "Create" ? "active" : "")"
               asp-controller="NotasServicio" asp-action="Create">
                <span class="material-icons-round">add</span>
                <span class="nav-text">Nueva Nota</span>
            </a>
            <a class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "NotasServicio" && ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")"
               asp-controller="NotasServicio" asp-action="Index">
                <span class="material-icons-round">history</span>
                <span class="nav-text">Historial de Servicios</span>
            </a>
            <span class="nav-label" style="margin-top:16px">Maestros</span>
            <a class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Clientes" ? "active" : "")"
               asp-controller="Clientes" asp-action="Index">
                <span class="material-icons-round">group</span>
                <span class="nav-text">Clientes</span>
            </a>
            <a class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Vehiculos" ? "active" : "")"
               asp-controller="Vehiculos" asp-action="Index">
                <span class="material-icons-round">directions_car</span>
                <span class="nav-text">Vehículos</span>
            </a>
            <span class="nav-label" style="margin-top:16px">Recursos</span>
            <a class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Inventario" ? "active" : "")"
               asp-controller="Inventario" asp-action="Index">
                <span class="material-icons-round">handyman</span>
                <span class="nav-text">Inventario</span>
            </a>
        </div>

        <div class="sidebar-footer">
            @if (User.Identity?.IsAuthenticated == true)
            {
                var email = User.Identity.Name;
                var initial = !string.IsNullOrEmpty(email) ? email[0].ToString().ToUpper() : "U";

                <div class="avatar" style="background-color: #3b82f6; color: white;">@initial</div>
                <div class="sidebar-footer-info">
                    <div class="user-name" title="@email">@email</div>
                    <div class="user-role">Administrador</div>
                </div>
                <form asp-controller="Account" asp-action="Logout" method="post" style="margin: 0;">
                    <button type="submit" style="background: none; border: none; color: rgba(255,255,255,0.55); cursor: pointer; padding: 4px;" title="Cerrar sesión">
                        <span class="material-icons-round" style="font-size: 20px;">logout</span>
                    </button>
                </form>
            }
            else
            {
                <div class="avatar">?</div>
                <div class="sidebar-footer-info">
                    <div class="user-name">Invitado</div>
                    <div class="user-role">No autenticado</div>
                </div>
            }
        </div>
    </nav>

    <!-- ══ MAIN ══ -->
    <!-- Botón flotante para abrir sidebar en móvil -->
    <button class="sidebar-open-btn" id="sidebarOpenBtn" title="Abrir menú" aria-label="Abrir menú">
        <span class="material-icons-round">menu</span>
    </button>
    <main class="main-content">
        @if (TempData["Success"] != null)
        {
            <div style="padding:16px 32px 0">
                <div class="toast-success">
                    <span class="material-icons-round" style="font-size:18px">check_circle</span>
                    @TempData["Success"]
                </div>
            </div>
        }

        @RenderBody()
    </main>
</div>

@await RenderSectionAsync("Scripts", required: false)

<script>
(function () {
    const sidebar     = document.getElementById('sidebar');
    const toggle      = document.getElementById('sidebarToggle');
    const openBtn     = document.getElementById('sidebarOpenBtn');
    const overlay     = document.getElementById('sidebarOverlay');
    const mainContent = document.querySelector('.main-content');
    const MOBILE_BP   = 768;
    const STORAGE_KEY = 'dn_sidebar_collapsed';

    // Leer variables CSS
    const rootStyle       = getComputedStyle(document.documentElement);
    const sidebarW        = rootStyle.getPropertyValue('--sidebar-w').trim();        // '240px'
    const sidebarCollapW  = rootStyle.getPropertyValue('--sidebar-collapsed-w').trim(); // '64px'

    function isMobile() { return window.innerWidth <= MOBILE_BP; }

    function setCollapsed(collapsed, save) {
        if (collapsed) {
            sidebar.classList.add('collapsed');
            toggle.querySelector('.material-icons-round').textContent = 'menu';
            toggle.setAttribute('title', 'Expandir menú');
        } else {
            sidebar.classList.remove('collapsed');
            toggle.querySelector('.material-icons-round').textContent = 'menu_open';
            toggle.setAttribute('title', 'Colapsar menú');
        }

        if (isMobile()) {
            // Móvil: overlay + botón flotante; main siempre margin 0
            overlay.classList.toggle('visible', !collapsed);
            openBtn.classList.toggle('visible', collapsed);
            mainContent.style.marginLeft = '0';
        } else {
            // Desktop: ajustar margin del contenido principal
            overlay.classList.remove('visible');
            openBtn.classList.remove('visible');
            mainContent.style.marginLeft = collapsed ? sidebarCollapW : sidebarW;
        }

        if (save) sessionStorage.setItem(STORAGE_KEY, collapsed ? '1' : '0');
    }

    function initSidebar() {
        if (isMobile()) {
            setCollapsed(true, false);
        } else {
            const saved = sessionStorage.getItem(STORAGE_KEY);
            setCollapsed(saved === '1', false);
        }
    }

    toggle.addEventListener('click', function () {
        setCollapsed(!sidebar.classList.contains('collapsed'), true);
    });

    openBtn.addEventListener('click', function () {
        setCollapsed(false, true);
    });

    overlay.addEventListener('click', function () {
        setCollapsed(true, true);
    });

    // Responsive: ajustar al cambiar tamaño de ventana
    let resizeTimer;
    window.addEventListener('resize', function () {
        clearTimeout(resizeTimer);
        resizeTimer = setTimeout(function () {
            if (isMobile()) {
                setCollapsed(true, false);
            } else {
                const saved = sessionStorage.getItem(STORAGE_KEY);
                setCollapsed(saved === '1', false);
            }
        }, 150);
    });

    initSidebar();
})();
</script>
</body>
</html>
