@model DanimecApp.Models.NotaServicio
@using DanimecApp.Models
@{
    ViewData["Title"] = $"Nota {Model.Numero}";
    var estados = Enum.GetValues<EstadoServicio>();
}

<div class="page-header">
    <div class="d-flex align-center gap-16">
        <a asp-controller="NotasServicio" asp-action="Index" class="btn-icon-dn">
            <span class="material-icons-round">arrow_back</span>
        </a>
        <div>
            <h1 class="page-title">@Model.Numero</h1>
            <p class="page-subtitle">Detalle y Gestión de Servicio</p>
        </div>
        <div class="ms-auto d-flex gap-8 align-center">
            @if (Model.Estado == EstadoServicio.Finalizado)
            {
                <button class="btn-primary-dn d-flex align-center gap-4" style="background-color:#e53935;color:white;border:none;padding:8px 16px;border-radius:8px;font-size:13px;font-weight:600" onclick="exportarPDF()">
                    <span class="material-icons-round" style="font-size:18px">picture_as_pdf</span> Exportar PDF
                </button>
            }
            @{
                var (chipCls, chipTxt) = Model.Estado switch {
                    EstadoServicio.EnProgreso => ("chip-progreso", "En Progreso"),
                    EstadoServicio.Cotizacion => ("chip-cotizacion", "Cotización"),
                    EstadoServicio.Finalizado => ("chip-finalizado", "Finalizado"),
                    EstadoServicio.Vencido    => ("chip-vencido",    "Vencido"),
                    _ => ("", "")
                };
            }
            <span class="chip @chipCls" style="font-size:13px;padding:6px 16px">@chipTxt</span>
            <!-- Change status -->
            <form asp-action="CambiarEstado" method="post" class="d-flex gap-8 align-center">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.Id" />
                <select name="estado" class="form-control-dn" style="min-width:140px;padding:8px 12px">
                    @foreach (var est in estados)
                    {
                        <option value="@((int)est)" selected="@(est == Model.Estado)">
                            @(est switch { EstadoServicio.EnProgreso=>"En Progreso", EstadoServicio.Cotizacion=>"Cotización", EstadoServicio.Finalizado=>"Finalizado", EstadoServicio.Vencido=>"Vencido", _=>"" })
                        </option>
                    }
                </select>
                <button type="submit" class="btn-ghost-dn" style="padding:8px 14px;font-size:12px">Actualizar Estado</button>
            </form>
        </div>
    </div>
</div>

<div class="page-body">
<div class="detail-layout">

    <!-- LEFT COLUMN -->
    <div>

        <!-- Client & Vehicle Info -->
        <div class="form-card mb-16">
            <div class="form-section-title">Información del Cliente y Vehículo</div>
            <div class="info-grid" style="margin-bottom:16px">
                <div class="info-field">
                    <div class="info-label">Cliente</div>
                    <div class="info-value">@Model.Cliente?.NombreCompleto</div>
                </div>
                <div class="info-field">
                    <div class="info-label">Empresa</div>
                    <div class="info-value">@(Model.Cliente?.Empresa ?? "—")</div>
                </div>
                <div class="info-field">
                    <div class="info-label">Teléfono</div>
                    <div class="info-value">@(Model.Cliente?.Telefono ?? "—")</div>
                </div>
                <div class="info-field">
                    <div class="info-label">Email</div>
                    <div class="info-value">@(Model.Cliente?.Email ?? "—")</div>
                </div>
            </div>
            <div class="info-grid">
                <div class="info-field">
                    <div class="info-label">Vehículo</div>
                    <div class="info-value">@Model.Vehiculo?.Marca @Model.Vehiculo?.Modelo @Model.Vehiculo?.Anio</div>
                </div>
                <div class="info-field">
                    <div class="info-label">Placa</div>
                    <div class="info-value" style="color:var(--primary-container)">@Model.Vehiculo?.Placa</div>
                </div>
                <div class="info-field">
                    <div class="info-label">Color</div>
                    <div class="info-value">@(Model.Vehiculo?.Color ?? "—")</div>
                </div>
                <div class="info-field">
                    <div class="info-label">KM Actual</div>
                    <div class="info-value">@(Model.Vehiculo?.KmActual?.ToString("N0") ?? "—") km</div>
                </div>
                <div class="info-field" style="grid-column:1/-1">
                    <div class="info-label">Motivo de Ingreso</div>
                    <div class="info-value" style="font-weight:400;font-size:13px">@(Model.MotivoIngreso ?? "—")</div>
                </div>
            </div>
        </div>

        <!-- Trabajos Realizados -->
        <div class="data-section mb-16">
            <div class="section-header">
                <div class="section-title">Trabajos Realizados</div>
                <button class="btn-ghost-dn" style="font-size:12px;padding:6px 12px" onclick="toggleModal('modalTrabajo')">
                    <span class="material-icons-round" style="font-size:16px">add</span> Agregar
                </button>
            </div>
            <table class="dn-table">
                <thead>
                    <tr>
                        <th>Descripción</th>
                        <th>Técnico</th>
                        <th class="right">Precio Unit.</th>
                        <th class="right">Cant.</th>
                        <th class="right">Total</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var t in Model.TrabajosRealizados)
                    {
                        <tr>
                            <td>@t.Descripcion</td>
                            <td class="muted">@(t.Tecnico ?? "—")</td>
                            <td class="right">Bs @t.PrecioUnitario.ToString("N2")</td>
                            <td class="right">@t.Cantidad</td>
                            <td class="right fw-semibold">Bs @((t.PrecioUnitario * t.Cantidad).ToString("N2"))</td>
                        </tr>
                    }
                    @if (!Model.TrabajosRealizados.Any())
                    {
                        <tr><td colspan="5" style="text-align:center;padding:24px;color:var(--on-surface-variant)">Sin trabajos registrados.</td></tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Repuestos y Materiales -->
        <div class="data-section mb-16">
            <div class="section-header">
                <div class="section-title">Repuestos y Materiales</div>
                <button class="btn-ghost-dn" style="font-size:12px;padding:6px 12px" onclick="toggleModal('modalRepuesto')">
                    <span class="material-icons-round" style="font-size:16px">add</span> Agregar
                </button>
            </div>
            <table class="dn-table">
                <thead>
                    <tr>
                        <th>Descripción</th>
                        <th class="right">Precio Unit.</th>
                        <th class="right">Cant.</th>
                        <th class="right">Total</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in Model.RepuestosServicios)
                    {
                        <tr>
                            <td>
                                @r.Descripcion
                                @if (r.InventarioItem != null)
                                {
                                    <span class="chip chip-progreso" style="margin-left:8px;font-size:10px">@r.InventarioItem.Codigo</span>
                                }
                            </td>
                            <td class="right">Bs @r.PrecioUnitario.ToString("N2")</td>
                            <td class="right">@r.Cantidad</td>
                            <td class="right fw-semibold">Bs @((r.PrecioUnitario * r.Cantidad).ToString("N2"))</td>
                        </tr>
                    }
                    @if (!Model.RepuestosServicios.Any())
                    {
                        <tr><td colspan="4" style="text-align:center;padding:24px;color:var(--on-surface-variant)">Sin repuestos registrados.</td></tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Trabajos Externos -->
        <div class="data-section">
            <div class="section-header">
                <div class="section-title">Trabajos Externos</div>
                <button class="btn-ghost-dn" style="font-size:12px;padding:6px 12px" onclick="toggleModal('modalExterno')">
                    <span class="material-icons-round" style="font-size:16px">add</span> Agregar
                </button>
            </div>
            <table class="dn-table">
                <thead>
                    <tr>
                        <th>Proveedor</th>
                        <th>Descripción</th>
                        <th>Factura</th>
                        <th class="right">Monto</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var e in Model.TrabajosExternos)
                    {
                        <tr>
                            <td class="fw-semibold">@e.Proveedor</td>
                            <td class="muted">@e.Descripcion</td>
                            <td>
                                <span class="chip @(e.FacturaAdjunta ? "chip-finalizado" : "chip-vencido")">
                                    @(e.FacturaAdjunta ? "Adjunta" : "Pendiente")
                                </span>
                            </td>
                            <td class="right fw-semibold">Bs @e.Monto.ToString("N2")</td>
                        </tr>
                    }
                    @if (!Model.TrabajosExternos.Any())
                    {
                        <tr><td colspan="4" style="text-align:center;padding:24px;color:var(--on-surface-variant)">Sin trabajos externos.</td></tr>
                    }
                </tbody>
            </table>
            @if (Model.TrabajosExternos.Any())
            {
                <div class="diagnostic-card" style="margin:16px">
                    <div class="diag-header">
                        <span class="material-icons-round">info</span>
                        <span class="diag-header-title">Aviso</span>
                    </div>
                    <div class="diag-body">Asegúrese de adjuntar todas las facturas de proveedores externos antes de proceder a la revisión final.</div>
                </div>
            }
        </div>
    </div>

    <!-- RIGHT SIDEBAR -->
    <div class="detail-sidebar">
        <div class="summary-box">
            <div style="font-size:11px;font-weight:700;letter-spacing:1px;text-transform:uppercase;opacity:.7;margin-bottom:16px">Resumen del Servicio</div>
            <div class="s-row">
                <span class="s-label">Cliente</span>
                <span class="s-value">@Model.Cliente?.NombreCompleto</span>
            </div>
            <div class="s-row">
                <span class="s-label">Vehículo</span>
                <span class="s-value">@Model.Vehiculo?.Marca @Model.Vehiculo?.Modelo (@Model.Vehiculo?.Placa)</span>
            </div>
            <div class="s-row">
                <span class="s-label">Fecha Entrada</span>
                <span class="s-value">@Model.FechaEntrada.ToString("dd MMM yyyy")</span>
            </div>
            <div class="s-row">
                <span class="s-label">Trabajos MO</span>
                <span class="s-value">Bs @Model.TrabajosRealizados.Sum(t => t.PrecioUnitario * t.Cantidad).ToString("N2")</span>
            </div>
            <div class="s-row">
                <span class="s-label">Repuestos</span>
                <span class="s-value">Bs @Model.RepuestosServicios.Sum(r => r.PrecioUnitario * r.Cantidad).ToString("N2")</span>
            </div>
            <div class="s-row">
                <span class="s-label">Trabajos Ext.</span>
                <span class="s-value">Bs @Model.TrabajosExternos.Sum(e => e.Monto).ToString("N2")</span>
            </div>
            <div class="s-row">
                <span class="s-label">SubTotal</span>
                <span class="s-value">Bs @Model.SubTotal.ToString("N2")</span>
            </div>
            <div class="s-row total">
                <span class="s-label">TOTAL</span>
                <span class="s-value">Bs @Model.Total.ToString("N2")</span>
            </div>
        </div>
    </div>

</div>
</div>

<!-- ══ INVOICE TEMPLATE FOR PDF ══ -->
<div style="position: absolute; left: -9999px; top: 0;">
    <div id="invoiceTemplate" style="width: 794px; padding: 30px; font-family: 'Inter', system-ui, sans-serif; background: #ffffff; color: #334155; box-sizing: border-box;">
        
        <!-- Header -->
        <div style="background-color: #1e3a8a; color: #ffffff; padding: 20px; border-radius: 8px; display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
            <div style="display: flex; gap: 16px; align-items: center;">
                <img src="/img/logo.png" alt="Logo PDF" style="height: 50px; max-width: 150px; object-fit: contain;" />
                <div>
                    <h1 style="margin: 0; color: #ffffff; font-size: 20px; font-weight: 800; text-transform: uppercase;"></h1>
                    <p style="margin: 4px 0 0 0; font-size: 11px; color: #e2e8f0;">Av. Banzer 6to anillo, barrio los sauces, calle A | Cel. 78585098</p>
                </div>
            </div>
            <div style="text-align: right;">
                <h2 style="margin: 0; font-size: 16px; font-weight: 700; color: #ffffff; text-transform: uppercase;">NOTA DE SERVICIO</h2>
                <div style="font-size: 14px; font-weight: 800; color: #fbbf24; margin-top: 4px;">Nº @Model.Numero</div>
                <p style="margin: 4px 0 0 0; font-size: 11px; color: #e2e8f0;">Fecha: @Model.FechaEntrada.ToString("dd/MM/yyyy") | Estado: <strong>FINALIZADO</strong></p>
            </div>
        </div>

        <!-- Client & Vehicle Details -->
        <div style="display: flex; gap: 15px; margin-bottom: 20px;">
            <div style="flex: 1; border: 1px solid #cbd5e1; padding: 10px; border-radius: 4px;">
                <h3 style="margin: 0 0 8px 0; color: #1e3a8a; font-size: 11px; text-transform: uppercase; font-weight: 700; border-bottom: 1px solid #e2e8f0; padding-bottom: 4px;">Datos del Cliente</h3>
                <div style="display: grid; grid-template-columns: 60px 1fr; gap: 4px; font-size: 11px;">
                    <span style="color: #64748b; font-weight: 600;">Nombre:</span> <span style="color: #0f172a; font-weight: 600;">@Model.Cliente?.NombreCompleto</span>
                    <span style="color: #64748b; font-weight: 600;">Tel:</span> <span style="color: #0f172a;">@(Model.Cliente?.Telefono ?? "—")</span>
                    <span style="color: #64748b; font-weight: 600;">Email:</span> <span style="color: #0f172a;">@(Model.Cliente?.Email ?? "—")</span>
                </div>
            </div>
            <div style="flex: 1; border: 1px solid #cbd5e1; padding: 10px; border-radius: 4px;">
                <h3 style="margin: 0 0 8px 0; color: #1e3a8a; font-size: 11px; text-transform: uppercase; font-weight: 700; border-bottom: 1px solid #e2e8f0; padding-bottom: 4px;">Datos del Vehículo</h3>
                <div style="display: grid; grid-template-columns: 60px 1fr; gap: 4px; font-size: 11px;">
                    <span style="color: #64748b; font-weight: 600;">Vehículo:</span> <span style="color: #0f172a;">@Model.Vehiculo?.Marca @Model.Vehiculo?.Modelo @Model.Vehiculo?.Anio</span>
                    <span style="color: #64748b; font-weight: 600;">Placa:</span> <span style="color: #0f172a; font-weight: 700;">@Model.Vehiculo?.Placa</span>
                    <span style="color: #64748b; font-weight: 600;">KM:</span> <span style="color: #0f172a;">@(Model.Vehiculo?.KmActual?.ToString("N0") ?? "—") km</span>
                </div>
            </div>
        </div>

        <!-- Motivo de Ingreso -->
        <div style="margin-bottom: 16px;">
            <h3 style="margin: 0 0 6px 0; color: #1e3a8a; font-size: 12px; font-weight: 700; text-transform: uppercase;">Motivo de Ingreso</h3>
            <div style="border: 1px solid #cbd5e1; border-radius: 4px; padding: 10px; font-size: 11px; color: #1e293b; background: #f8fafc;">
                @(string.IsNullOrWhiteSpace(Model.MotivoIngreso) ? "Sin motivo de ingreso registrado." : Model.MotivoIngreso)
            </div>
        </div>

        <!-- 1. Trabajos Realizados -->
        <div style="margin-bottom: 16px;">
            <h3 style="margin: 0 0 6px 0; color: #1e3a8a; font-size: 12px; font-weight: 700; text-transform: uppercase;">1. Trabajos Realizados</h3>
            <table style="width: 100%; border-collapse: collapse; font-size: 11px; border: 1px solid #cbd5e1;">
                <thead>
                    <tr style="background-color: #1e3a8a; color: #ffffff;">
                        <th style="padding: 6px 10px; text-align: left; font-weight: 600; border: 1px solid #1e3a8a;">Descripción</th>
                        <th style="padding: 6px 10px; text-align: center; font-weight: 600; border: 1px solid #1e3a8a; width: 60px;">Cant.</th>
                        <th style="padding: 6px 10px; text-align: right; font-weight: 600; border: 1px solid #1e3a8a; width: 80px;">Precio</th>
                        <th style="padding: 6px 10px; text-align: right; font-weight: 600; border: 1px solid #1e3a8a; width: 90px;">Subtotal</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var t in Model.TrabajosRealizados)
                    {
                        <tr style="border-bottom: 1px solid #e2e8f0;">
                            <td style="padding: 6px 10px; color: #1e293b; border-right: 1px solid #e2e8f0;">@t.Descripcion</td>
                            <td style="padding: 6px 10px; text-align: center; color: #475569; border-right: 1px solid #e2e8f0;">@t.Cantidad</td>
                            <td style="padding: 6px 10px; text-align: right; color: #475569; border-right: 1px solid #e2e8f0;">Bs @t.PrecioUnitario.ToString("N2")</td>
                            <td style="padding: 6px 10px; text-align: right; font-weight: 600; color: #0f172a;">Bs @((t.PrecioUnitario * t.Cantidad).ToString("N2"))</td>
                        </tr>
                    }
                    @if (!Model.TrabajosRealizados.Any())
                    {
                        <tr><td colspan="4" style="padding: 8px; text-align: center; color: #94a3b8; font-style: italic;">Sin trabajos registrados.</td></tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- 2. Repuestos y Materiales -->
        <div style="margin-bottom: 16px;">
            <h3 style="margin: 0 0 6px 0; color: #1e3a8a; font-size: 12px; font-weight: 700; text-transform: uppercase;">2. Repuestos y Materiales</h3>
            <table style="width: 100%; border-collapse: collapse; font-size: 11px; border: 1px solid #cbd5e1;">
                <thead>
                    <tr style="background-color: #1e3a8a; color: #ffffff;">
                        <th style="padding: 6px 10px; text-align: left; font-weight: 600; border: 1px solid #1e3a8a;">Repuesto / Material</th>
                        <th style="padding: 6px 10px; text-align: center; font-weight: 600; border: 1px solid #1e3a8a; width: 60px;">Cant.</th>
                        <th style="padding: 6px 10px; text-align: right; font-weight: 600; border: 1px solid #1e3a8a; width: 80px;">Precio Unit.</th>
                        <th style="padding: 6px 10px; text-align: right; font-weight: 600; border: 1px solid #1e3a8a; width: 90px;">Subtotal</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in Model.RepuestosServicios)
                    {
                        <tr style="border-bottom: 1px solid #e2e8f0;">
                            <td style="padding: 6px 10px; color: #1e293b; border-right: 1px solid #e2e8f0;">@r.Descripcion</td>
                            <td style="padding: 6px 10px; text-align: center; color: #475569; border-right: 1px solid #e2e8f0;">@r.Cantidad</td>
                            <td style="padding: 6px 10px; text-align: right; color: #475569; border-right: 1px solid #e2e8f0;">Bs @r.PrecioUnitario.ToString("N2")</td>
                            <td style="padding: 6px 10px; text-align: right; font-weight: 600; color: #0f172a;">Bs @((r.PrecioUnitario * r.Cantidad).ToString("N2"))</td>
                        </tr>
                    }
                    @if (!Model.RepuestosServicios.Any())
                    {
                        <tr><td colspan="4" style="padding: 8px; text-align: center; color: #94a3b8; font-style: italic;">Sin repuestos registrados.</td></tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- 3. Trabajos Externos -->
        <div style="margin-bottom: 20px;">
            <h3 style="margin: 0 0 6px 0; color: #1e3a8a; font-size: 12px; font-weight: 700; text-transform: uppercase;">3. Trabajos Externos</h3>
            <table style="width: 100%; border-collapse: collapse; font-size: 11px; border: 1px solid #cbd5e1;">
                <thead>
                    <tr style="background-color: #1e3a8a; color: #ffffff;">
                        <th style="padding: 6px 10px; text-align: left; font-weight: 600; border: 1px solid #1e3a8a;">Descripción</th>
                        <th style="padding: 6px 10px; text-align: left; font-weight: 600; border: 1px solid #1e3a8a;">Proveedor</th>
                        <th style="padding: 6px 10px; text-align: right; font-weight: 600; border: 1px solid #1e3a8a; width: 80px;">Costo</th>
                        <th style="padding: 6px 10px; text-align: right; font-weight: 600; border: 1px solid #1e3a8a; width: 90px;">Subtotal</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var e in Model.TrabajosExternos)
                    {
                        <tr style="border-bottom: 1px solid #e2e8f0;">
                            <td style="padding: 6px 10px; color: #1e293b; border-right: 1px solid #e2e8f0;">@e.Descripcion</td>
                            <td style="padding: 6px 10px; color: #475569; border-right: 1px solid #e2e8f0;">@e.Proveedor</td>
                            <td style="padding: 6px 10px; text-align: right; color: #475569; border-right: 1px solid #e2e8f0;">Bs @e.Monto.ToString("N2")</td>
                            <td style="padding: 6px 10px; text-align: right; font-weight: 600; color: #0f172a;">Bs @e.Monto.ToString("N2")</td>
                        </tr>
                    }
                    @if (!Model.TrabajosExternos.Any())
                    {
                        <tr><td colspan="4" style="padding: 8px; text-align: center; color: #94a3b8; font-style: italic;">Sin trabajos externos registrados.</td></tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Summary Totals -->
        <div style="display: flex; justify-content: flex-end;">
            <div style="width: 280px; border: 1px solid #cbd5e1; border-radius: 4px; overflow: hidden;">
                <div style="display: flex; justify-content: space-between; padding: 6px 12px; font-size: 11px; color: #475569; background: #ffffff; border-bottom: 1px solid #e2e8f0;">
                    <span>Total Trabajos:</span>
                    <span style="font-weight: 600; color: #0f172a;">Bs @Model.TrabajosRealizados.Sum(t => t.PrecioUnitario * t.Cantidad).ToString("N2")</span>
                </div>
                <div style="display: flex; justify-content: space-between; padding: 6px 12px; font-size: 11px; color: #475569; background: #ffffff; border-bottom: 1px solid #e2e8f0;">
                    <span>Total Repuestos:</span>
                    <span style="font-weight: 600; color: #0f172a;">Bs @Model.RepuestosServicios.Sum(r => r.PrecioUnitario * r.Cantidad).ToString("N2")</span>
                </div>
                <div style="display: flex; justify-content: space-between; padding: 6px 12px; font-size: 11px; color: #475569; background: #f8fafc; border-bottom: 1px solid #cbd5e1;">
                    <span>Total Externos:</span>
                    <span style="font-weight: 600; color: #0f172a;">Bs @Model.TrabajosExternos.Sum(e => e.Monto).ToString("N2")</span>
                </div>
                <!-- Highlighted Total Box -->
                <div style="background-color: #1e3a8a; color: #ffffff; padding: 10px 12px; display: flex; justify-content: space-between; align-items: center;">
                    <span style="font-size: 12px; font-weight: 700; text-transform: uppercase;">TOTAL FINAL:</span>
                    <span style="font-size: 16px; font-weight: 800;">Bs @Model.Total.ToString("N2")</span>
                </div>
            </div>
        </div>

        <!-- Footer / Thank you message -->
        <div style="margin-top: 40px; text-align: center; border-top: 1px solid #cbd5e1; padding-top: 16px;">
            <p style="margin: 0; font-size: 12px; font-weight: 700; color: #1e3a8a;">¡Gracias por su preferencia y confianza!</p>
            <p style="margin: 4px 0 0 0; font-size: 10px; color: #64748b;">Su vehículo está en las mejores manos. Para cualquier consulta o garantía, conserve este documento.</p>
        </div>

    </div>
</div>

